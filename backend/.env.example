# PIM AI Coach — Environment Configuration
# Copy this file to .env and fill in your values

# -- Database (Neon PostgreSQL with pgvector) --
PIM_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -- LLM Provider API Keys --
PIM_ANTHROPIC_API_KEY=sk-ant-...
PIM_OPENAI_API_KEY=sk-...
# PIM_COHERE_API_KEY=              # Optional: for Cohere embeddings/reranking

# -- Vercel Blob (document storage from pimrepository) --
# PIM_BLOB_READ_WRITE_TOKEN=      # Optional: to pull docs from Vercel Blob

# -- RAG Pipeline Config (all optional — defaults in config.py) --
# PIM_CHUNKER=recursive            # recursive | semantic | by_section
# PIM_CHUNK_SIZE=1000
# PIM_CHUNK_OVERLAP=200
# PIM_EMBEDDING_MODEL=openai       # openai | cohere | huggingface
# PIM_EMBEDDING_MODEL_NAME=text-embedding-3-small
# PIM_VECTOR_STORE=pgvector        # pgvector | chroma | faiss
# PIM_RETRIEVER_TYPE=similarity    # similarity | mmr | self_query
# PIM_RETRIEVER_K=6
# PIM_RERANKER=                    # (empty) | cohere | cross_encoder
# PIM_LLM_PROVIDER=anthropic       # anthropic | openai | ollama
# PIM_LLM_MODEL=claude-sonnet-4-20250514
# PIM_LLM_TEMPERATURE=0.2
# PIM_CHAIN_TYPE=stuff              # stuff | map_reduce | refine
